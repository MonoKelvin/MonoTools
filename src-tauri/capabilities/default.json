{
  "$schema": "https://schema.tauri.app/config/2.0/capability",
  "identifier": "default",
  "description": "Default capabilities for MonoTools",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-center",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "core:window:allow-set-always-on-top",
    "core:app:allow-version",
    "core:app:allow-name",
    "core:app:allow-exit",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "path:default",
    "path:allow-resolve-directory",
    "path:allow-resolve",
    "path:allow-exists",
    "clipboard:default",
    "clipboard:allow-read-text",
    "clipboard:allow-write-text",
    "shell:default",
    "shell:allow-open",
    "http:default",
    "http:allow-fetch",
    "notification:default",
    "notification:allow-notification",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
